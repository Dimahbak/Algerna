# ─── Serveur ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de données PostgreSQL ────────────────────────────
DATABASE_URL=postgresql://civismart:change_me@localhost:5432/civismart
# Alternative en variables séparées (si DATABASE_URL absent) :
PGHOST=localhost
PGPORT=5432
PGUSER=civismart
PGPASSWORD=change_me
PGDATABASE=civismart

# ─── Authentification ──────────────────────────────────────
JWT_SECRET=remplacer_par_une_longue_chaine_aleatoire
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── Upload photos ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_PHOTO_MB=5

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=*
