# Disable LiteSpeed cache for this vhost
CacheDisable public
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>

# No-cache headers for HTML and JS
<FilesMatch "\.(html|js)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>
